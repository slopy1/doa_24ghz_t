options:
  parameters:
    author: DoA Thesis Project
    catch_exceptions: 'True'
    category: '[AoA Estimation]'
    cmake_opt: ''
    comment: AoA estimation flowgraph for BladeRF 2.0 MIMO\nBased on Wachowiak & Kryszkiewicz
      (2022)\nUses Root-MUSIC algorithm
    copyright: ''
    description: Real-time Direction of Arrival estimation using Root-MUSIC
    gen_cmake: 'On'
    gen_linking: dynamic
    generate_options: qt_gui
    hier_block_src_path: '.:'
    id: aoa_estimation_bladerf
    max_nouts: '0'
    output_language: python
    placement: (0,0)
    qt_qss_theme: ''
    realtime_scheduling: ''
    run: 'True'
    run_command: '{python} -u {filename}'
    run_options: prompt
    sizing_mode: fixed
    thread_safe_setters: ''
    title: BladeRF AoA Estimation (Root-MUSIC)
    window_size: ''
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [8, 8]
    rotation: 0
    state: enabled

blocks:
- name: antenna_spacing
  id: variable
  parameters:
    comment: Normalized spacing d/lambda = 0.5 for lambda/2
    value: '0.5'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [920, 12.0]
    rotation: 0
    state: enabled
- name: center_freq
  id: variable
  parameters:
    comment: ''
    value: 2.42e9
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [184, 12.0]
    rotation: 0
    state: enabled
- name: phase_cal_deg
  id: variable_qtgui_range
  parameters:
    comment: Enter the calibration coefficient from phase_calibration flowgraph
    gui_hint: 0,1,1,1
    label: Phase Cal (deg)
    min_len: '200'
    orient: QtCore.Qt.Horizontal
    rangeType: float
    start: '-180'
    step: '0.1'
    stop: '180'
    value: '0'
    widget: counter_slider
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [560, 0.0]
    rotation: 0
    state: enabled
- name: phase_cal_rad
  id: variable
  parameters:
    comment: ''
    value: phase_cal_deg * 3.14159265359 / 180.0
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1048, 12.0]
    rotation: 0
    state: enabled
- name: rx_gain
  id: variable_qtgui_range
  parameters:
    comment: ''
    gui_hint: 0,0,1,1
    label: RX Gain (dB)
    min_len: '200'
    orient: QtCore.Qt.Horizontal
    rangeType: float
    start: '0'
    step: '1'
    stop: '60'
    value: '40'
    widget: counter_slider
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [400, 0.0]
    rotation: 0
    state: enabled
- name: sample_rate
  id: variable
  parameters:
    comment: ''
    value: 1e6
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [304, 16.0]
    rotation: 0
    state: enabled
- name: snapshot_size
  id: variable
  parameters:
    comment: 'Samples per MUSIC snapshot (per paper: 1024)'
    value: '1024'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [800, 40.0]
    rotation: 0
    state: enabled
- name: tone_freq
  id: variable
  parameters:
    comment: TX tone offset frequency
    value: 50e3
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [688, 12.0]
    rotation: 0
    state: enabled
- name: analog_const_source_x_0
  id: analog_const_source_x
  parameters:
    affinity: ''
    alias: ''
    comment: Calibration phase in radians
    const: phase_cal_rad
    maxoutbuf: '0'
    minoutbuf: '0'
    type: float
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [664.0, 808]
    rotation: 90
    state: enabled
- name: aoa_autocorrelate_0
  id: aoa_autocorrelate
  parameters:
    affinity: ''
    alias: ''
    avg_method: '0'
    comment: Compute covariance matrix for MUSIC
    maxoutbuf: '0'
    minoutbuf: '0'
    num_inputs: '2'
    overlap_size: '0'
    snapshot_size: snapshot_size
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [936, 472.0]
    rotation: 0
    state: enabled
- name: aoa_music_lin_array_0
  id: aoa_music_lin_array
  parameters:
    affinity: ''
    alias: ''
    comment: MUSIC pseudo-spectrum for visualization
    maxoutbuf: '0'
    minoutbuf: '0'
    norm_spacing: antenna_spacing
    num_inputs: '2'
    num_targets: '1'
    pspectrum_len: '1024'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1312, 712.0]
    rotation: 0
    state: enabled
- name: aoa_root_music_linear_array_0
  id: aoa_root_music_linear_array
  parameters:
    affinity: ''
    alias: ''
    comment: Root-MUSIC DoA estimator\n2 elements, 1 source, lambda/2 spacing
    maxoutbuf: '0'
    minoutbuf: '0'
    norm_spacing: antenna_spacing
    num_inputs: '2'
    num_targets: '1'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1312, 384.0]
    rotation: 0
    state: enabled
- name: aoa_shift_phase_0
  id: aoa_shift_phase_multiple_hier
  parameters:
    affinity: ''
    alias: ''
    comment: Apply phase calibration coefficient to CH1
    dummy_param: ''
    maxoutbuf: '0'
    minoutbuf: '0'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [760, 648.0]
    rotation: 0
    state: enabled
- name: band_pass_filter_0
  id: band_pass_filter
  parameters:
    affinity: ''
    alias: ''
    beta: '6.76'
    comment: Filter CH0
    decim: '1'
    gain: '1'
    high_cutoff_freq: tone_freq + 10e3
    interp: '1'
    low_cutoff_freq: tone_freq - 10e3
    maxoutbuf: '0'
    minoutbuf: '0'
    samp_rate: sample_rate
    type: fir_filter_ccf
    width: '5000'
    win: window.WIN_HAMMING
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [432, 244.0]
    rotation: 0
    state: enabled
- name: band_pass_filter_1
  id: band_pass_filter
  parameters:
    affinity: ''
    alias: ''
    beta: '6.76'
    comment: Filter CH1
    decim: '1'
    gain: '1'
    high_cutoff_freq: tone_freq + 10e3
    interp: '1'
    low_cutoff_freq: tone_freq - 10e3
    maxoutbuf: '0'
    minoutbuf: '0'
    samp_rate: sample_rate
    type: fir_filter_ccf
    width: '5000'
    win: window.WIN_HAMMING
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [432, 588.0]
    rotation: 0
    state: enabled
- name: qtgui_freq_sink_x_0
